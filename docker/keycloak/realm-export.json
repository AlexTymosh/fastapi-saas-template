{
  "id": "fastapi-saas",
  "realm": "fastapi-saas",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "superadmin"
      },
      {
        "name": "member"
      }
    ]
  },
  "clients": [
    {
      "clientId": "fastapi-web",
      "name": "fastapi-web",
      "description": "Browser/public client for local Authorization Code + PKCE login.",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:3000/auth/callback",
        "http://127.0.0.1:3000/auth/callback",
        "http://localhost:5173/auth/callback",
        "http://127.0.0.1:5173/auth/callback",
        "http://localhost:8787/callback",
        "http://127.0.0.1:8787/callback"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://localhost:8787",
        "http://127.0.0.1:8787"
      ],
      "protocolMappers": [
        {
          "name": "aud-fastapi-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "fastapi-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "fastapi-api",
      "name": "fastapi-api",
      "description": "API/resource audience descriptor used for access token aud validation by FastAPI.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "roles"
      ]
    }
  ],
  "users": [
    {
      "username": "api-user",
      "enabled": true,
      "email": "api-user@example.com",
      "emailVerified": true,
      "firstName": "Api",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "api-user-password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "member"
      ]
    }
  ]
}
