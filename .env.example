APP__NAME=SaaS Template
APP__VERSION=0.1.0
APP__ENVIRONMENT=local
APP__DEBUG=false

API__V1_PREFIX=/api/v1
API__DOCS_ENABLED=true
API__OPENAPI_URL=/openapi.json
API__SCALAR_PATH=/scalar

LOGGING__LEVEL=INFO
LOGGING__AS_JSON=true

REQUEST_CONTEXT__HEADER_NAME=X-Request-ID
REQUEST_CONTEXT__TRUST_INCOMING_REQUEST_ID=true

VAULT__ENABLED=true
VAULT__ADDR=http://vault:8200
VAULT__TOKEN=dev-only-root-token
VAULT__MOUNT=secret
VAULT__PATH=fastapi-saas-template
VAULT__AUTH_METHOD=token
VAULT__FAIL_FAST=false

DATABASE__URL=postgresql+psycopg://app:app@localhost:5432/fastapi_saas_template
DATABASE__ECHO=false
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=20
DATABASE__POOL_TIMEOUT=30
DATABASE__POOL_RECYCLE=1800
DATABASE__HEALTHCHECK_TIMEOUT=1.0

REDIS__URL=
REDIS__HEALTHCHECK_TIMEOUT=0.5

# Observability
# By default metrics use OpenTelemetry API no-op behavior.
# Optional local OTLP collector:
# docker compose --profile observability up
# OBSERVABILITY__METRICS_ENABLED=true
# OBSERVABILITY__EXPORTER=otlp
# OBSERVABILITY__OTLP_ENDPOINT=http://otel-collector:4318/v1/metrics
# Standard OTel env vars for deployment metadata and auth headers:
# OTEL_SERVICE_NAME=fastapi-saas-template
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment.name=production,service.version=1.2.0
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <token>
# OTEL_EXPORTER_OTLP_METRICS_HEADERS=Authorization=Bearer <token>
# OTEL_EXPORTER_OTLP_METRICS_COMPRESSION=gzip
OBSERVABILITY__METRICS_ENABLED=false
OBSERVABILITY__EXPORTER=none
OBSERVABILITY__OTLP_ENDPOINT=
OBSERVABILITY__SERVICE_NAME=
OBSERVABILITY__OTLP_TIMEOUT_SECONDS=2.0
OBSERVABILITY__EXPORT_INTERVAL_MILLIS=60000
OBSERVABILITY__EXPORT_TIMEOUT_MILLIS=2000

# Enable rate limiting explicitly with RATE_LIMITING__ENABLED=true and set REDIS__URL
# (Docker Compose: redis://redis:6379/0, local Redis: redis://localhost:6379/0).
# In staging/prod, disabled rate limiting fails fast unless
# RATE_LIMITING__ALLOW_DISABLED_IN_PROD=true is set explicitly.
RATE_LIMITING__ENABLED=false
RATE_LIMITING__ALLOW_DISABLED_IN_PROD=false
RATE_LIMITING__BACKEND=redis
RATE_LIMITING__REDIS_PREFIX=rate-limit
RATE_LIMITING__TRUST_PROXY_HEADERS=false
# Default policy settings below are used only by an explicit default policy factory.
# They are not attached automatically and do not create hidden fallback behavior.
RATE_LIMITING__DEFAULT_LIMIT=60
RATE_LIMITING__DEFAULT_WINDOW_SECONDS=60
RATE_LIMITING__DEFAULT_FAIL_OPEN=true
RATE_LIMITING__SENSITIVE_FAIL_OPEN=false
RATE_LIMITING__STORAGE_TIMEOUT_SECONDS=1.0

# Keycloak JWT validation (backend auth boundary)
# AUTH__CLIENT_ID is the browser/public login client used for resource_access role extraction.
# AUTH__AUDIENCE is the API/resource audience validated by FastAPI.
AUTH__ENABLED=false
AUTH__ISSUER_URL=http://keycloak.local:8080/realms/fastapi-saas
AUTH__AUDIENCE=fastapi-api
AUTH__CLIENT_ID=fastapi-web
AUTH__JWKS_URL=
AUTH__ALGORITHMS=RS256
AUTH__LEEWAY_SECONDS=30
AUTH__DISCOVERY_CACHE_TTL_SECONDS=300
AUTH__JWKS_CACHE_TTL_SECONDS=300

# Optional secret for confidential-client integrations outside the runtime JWT path.
SECURITY__KEYCLOAK_CLIENT_SECRET=
