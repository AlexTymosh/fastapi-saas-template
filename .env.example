APP__NAME=SaaS Template
APP__VERSION=0.1.0
APP__ENVIRONMENT=local
APP__DEBUG=false

API__V1_PREFIX=/api/v1
API__DOCS_ENABLED=true
API__OPENAPI_URL=/openapi.json
API__SCALAR_PATH=/scalar

LOGGING__LEVEL=INFO
LOGGING__AS_JSON=true

REQUEST_CONTEXT__HEADER_NAME=X-Request-ID
REQUEST_CONTEXT__TRUST_INCOMING_REQUEST_ID=true

VAULT__ENABLED=true
VAULT__ADDR=http://vault:8200
VAULT__TOKEN=dev-only-root-token
VAULT__MOUNT=secret
VAULT__PATH=fastapi-saas-template
VAULT__AUTH_METHOD=token
VAULT__FAIL_FAST=false

DATABASE__URL=
DATABASE__ECHO=false

REDIS__URL=

SECURITY__KEYCLOAK_SERVER_URL=
SECURITY__KEYCLOAK_REALM=
SECURITY__KEYCLOAK_CLIENT_ID=
SECURITY__KEYCLOAK_CLIENT_SECRET=