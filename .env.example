APP__NAME=SaaS Template
APP__VERSION=0.1.0
APP__ENVIRONMENT=local
APP__DEBUG=false

API__V1_PREFIX=/api/v1
API__DOCS_ENABLED=true
API__OPENAPI_URL=/openapi.json
API__SCALAR_PATH=/scalar

LOGGING__LEVEL=INFO
LOGGING__AS_JSON=true

REQUEST_CONTEXT__HEADER_NAME=X-Request-ID
REQUEST_CONTEXT__TRUST_INCOMING_REQUEST_ID=true

VAULT__ENABLED=true
VAULT__ADDR=http://vault:8200
VAULT__TOKEN=dev-only-root-token
VAULT__MOUNT=secret
VAULT__PATH=fastapi-saas-template
VAULT__AUTH_METHOD=token
VAULT__FAIL_FAST=false

DATABASE__URL=postgresql+psycopg://app:app@localhost:5432/fastapi_saas_template
DATABASE__ECHO=false
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=20
DATABASE__POOL_TIMEOUT=30
DATABASE__POOL_RECYCLE=1800
DATABASE__HEALTHCHECK_TIMEOUT=1.0

REDIS__URL=
REDIS__HEALTHCHECK_TIMEOUT=0.5

# Keycloak JWT validation (backend auth boundary)
AUTH__ENABLED=false
AUTH__ISSUER_URL=http://localhost:8080/realms/fastapi-saas
AUTH__AUDIENCE=fastapi-backend
AUTH__CLIENT_ID=fastapi-backend
AUTH__JWKS_URL=
AUTH__ALGORITHMS=RS256
AUTH__LEEWAY_SECONDS=30
AUTH__DISCOVERY_CACHE_TTL_SECONDS=300
AUTH__JWKS_CACHE_TTL_SECONDS=300

# Optional legacy/security values used in some environments.
# Runtime JWT principal mapping uses AUTH__CLIENT_ID.
SECURITY__KEYCLOAK_SERVER_URL=http://localhost:8080
SECURITY__KEYCLOAK_REALM=fastapi-saas
SECURITY__KEYCLOAK_CLIENT_ID=fastapi-backend
SECURITY__KEYCLOAK_CLIENT_SECRET=
